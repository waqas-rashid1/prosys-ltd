# Contact form email delivery
# All contact submissions are routed to CONTACT_TO_EMAIL.
# If unset, defaults to conveytowaqas@gmail.com (see src/app/api/contact/route.ts).
CONTACT_TO_EMAIL=conveytowaqas@gmail.com

# ───── Option A: Resend (preferred for production) ──────────────────────────
# Sign up at https://resend.com, verify your sending domain, then create an API key.
# CONTACT_FROM_EMAIL must be on a domain you have verified in Resend.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=noreply@prosysltd.com

# ───── Option B: Gmail SMTP (zero-cost fallback, used when RESEND_API_KEY unset) ─
# 1. Turn on 2-Step Verification on the Google account.
# 2. Visit https://myaccount.google.com/apppasswords and create an "App password"
#    for the app "Mail". Copy the 16-character password (spaces optional).
# 3. Set the values below. Mail will be sent FROM this Gmail account.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ───── Newsletter ───────────────────────────────────────────────────────────
# The newsletter API reuses the same transport (Resend → Gmail SMTP → dev log)
# and the same CONTACT_TO_EMAIL destination. Optionally, also store subscribers
# in a Resend Audience for marketing campaigns:
RESEND_AUDIENCE_ID=
